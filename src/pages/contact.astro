---
import Layout from '../layouts/Layout.astro';
import '../styles/contact.css';

// Read query param to pre-select service type (e.g. /contact?service=a-la-carte)
const serviceParam = Astro.url.searchParams.get('service') ?? '';
---

<Layout>
  <section class="contact-page">
    <div class="container">
      <div class="contact-grid">

        <!-- Left: Info column -->
        <div class="contact-info">
          <div>
            <span class="contact-tagline">Get In Touch</span>
            <h1 class="contact-title">
              Book Your Free<br/>
              <span>Consultation.</span>
            </h1>
          </div>
          <p class="contact-desc">
            We'll review your IKEA quote, walk through the scope of work, and provide a fully transparent cost estimate—no surprises, no obligation.
          </p>

          <div class="contact-details">
            <div class="contact-detail-item">
              <div class="detail-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
              </div>
              <div class="detail-text">
                <span class="detail-label">Email</span>
                <span class="detail-value">ikeakitcheninstalller.ca@gmail.com</span>
              </div>
            </div>

            <div class="contact-detail-item">
              <div class="detail-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
              </div>
              <div class="detail-text">
                <span class="detail-label">Warranty</span>
                <span class="detail-value">5-year workmanship guarantee</span>
              </div>
            </div>

            <div class="contact-detail-item">
              <div class="detail-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
              </div>
              <div class="detail-text">
                <span class="detail-label">Response Time</span>
                <span class="detail-value">Within 1 business day</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Right: Form column -->
        <div class="contact-form-wrapper">
          <h2 class="contact-form-title">Tell us about your project</h2>
          <p class="contact-form-subtitle">Fill in your details below and we'll be in touch to schedule your free consultation.</p>

          <!-- Status messages (shown by JS) -->
          <div id="form-success" class="form-status success" role="alert" style="display: none;">
            ✓ Message sent! We'll get back to you within one business day.
          </div>
          <div id="form-error" class="form-status error" role="alert" style="display: none;">
            Something went wrong. Please try again or email us directly at ikeakitcheninstalller.ca@gmail.com
          </div>

          <form id="contact-form" class="contact-form" novalidate>
            <div class="form-row">
              <div class="form-field">
                <label class="form-label" for="first-name">First Name <span>*</span></label>
                <input
                  id="first-name"
                  name="first_name"
                  type="text"
                  class="form-input"
                  placeholder="Jane"
                  required
                  autocomplete="given-name"
                />
              </div>
              <div class="form-field">
                <label class="form-label" for="last-name">Last Name <span>*</span></label>
                <input
                  id="last-name"
                  name="last_name"
                  type="text"
                  class="form-input"
                  placeholder="Doe"
                  required
                  autocomplete="family-name"
                />
              </div>
            </div>

            <div class="form-field">
              <label class="form-label" for="email">Email Address <span>*</span></label>
              <input
                id="email"
                name="email"
                type="email"
                class="form-input"
                placeholder="jane@example.com"
                required
                autocomplete="email"
              />
            </div>

            <div class="form-field">
              <label class="form-label" for="phone">Phone Number</label>
              <input
                id="phone"
                name="phone"
                type="tel"
                class="form-input"
                placeholder="(416) 555-0123"
                autocomplete="tel"
              />
            </div>

            <div class="form-field">
              <label class="form-label" for="service-type">Service Type <span>*</span></label>
              <select id="service-type" name="service_type" class="form-select" required>
                <option value="" disabled selected={serviceParam === ''}>Select a service...</option>
                <option value="Simple Installation" selected={serviceParam === 'simple-installation'}>Simple Installation</option>
                <option value="A La Carte" selected={serviceParam === 'a-la-carte'}>A La Carte</option>
                <option value="Fully Managed Remodel" selected={serviceParam === 'fully-managed-remodel'}>Fully Managed Remodel</option>
                <option value="Not sure yet">Not sure yet</option>
              </select>
            </div>

            <div class="form-field">
              <label class="form-label" for="message">Tell us about your project</label>
              <textarea
                id="message"
                name="message"
                class="form-textarea"
                placeholder="e.g. We have a full IKEA kitchen plan ready and need help with installation and plumbing connections..."
              ></textarea>
            </div>

            <button type="submit" class="form-submit" id="submit-btn">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
              Send Message
            </button>
          </form>
        </div>

      </div>
    </div>
  </section>
</Layout>

<!--
  ============================================================
  EmailJS SETUP INSTRUCTIONS
  ============================================================
  1. Create a free account at https://www.emailjs.com
  2. Connect your Gmail account under Email Services → Add New Service
     (choose Gmail, authenticate with ikeakitcheninstalller.ca@gmail.com)
     Note your Service ID (e.g. "service_xxxxxxx")

  3. Create an Email Template under Email Templates → Create New Template
     Set "To Email" field to: ikeakitcheninstalller.ca@gmail.com
     Use these template variables in the body:
       {{first_name}} {{last_name}}
       {{email}} {{phone}}
       {{service_type}}
       {{message}}
     Note your Template ID (e.g. "template_xxxxxxx")

  4. Copy your Public Key from Account → General
     (e.g. "XXXXXXXXXXXXXXX")

  5. Replace the three placeholder values below:
       EMAILJS_PUBLIC_KEY
       EMAILJS_SERVICE_ID
       EMAILJS_TEMPLATE_ID
  ============================================================
-->
<script>
  // ── EmailJS configuration ─────────────────────────────────
  // Replace these three values with your own from emailjs.com
  const EMAILJS_PUBLIC_KEY   = 'PPesJaSqTzpfrgnQ1';   // Your Public Key
  const EMAILJS_SERVICE_ID   = 'service_1k5yvyh';   // e.g. service_abc123
  const EMAILJS_TEMPLATE_ID  = 'template_e3mjg8p';  // e.g. template_xyz789
  // ─────────────────────────────────────────────────────────

  // Dynamically load the EmailJS browser SDK
  const script = document.createElement('script');
  script.src = 'https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js';
  script.async = true;
  document.head.appendChild(script);

  const form      = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn')   as HTMLButtonElement;
  const successEl = document.getElementById('form-success') as HTMLDivElement;
  const errorEl   = document.getElementById('form-error')   as HTMLDivElement;

  script.onload = () => {
    // @ts-ignore – emailjs is loaded from CDN
    window.emailjs.init({ publicKey: EMAILJS_PUBLIC_KEY });
  };

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Basic client-side validation
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending…';
    successEl.style.display = 'none';
    errorEl.style.display   = 'none';

    const formData = new FormData(form);
    const templateParams = {
      first_name:   formData.get('first_name'),
      last_name:    formData.get('last_name'),
      email:        formData.get('email'),
      phone:        formData.get('phone') || 'Not provided',
      service_type: formData.get('service_type'),
      message:      formData.get('message') || 'No additional message.',
    };

    try {
      // @ts-ignore
      await window.emailjs.send(EMAILJS_SERVICE_ID, EMAILJS_TEMPLATE_ID, templateParams);
      successEl.style.display = 'block';
      form.reset();
    } catch (err) {
      console.error('EmailJS error:', err);
      errorEl.style.display = 'block';
    } finally {
      submitBtn.disabled = false;
      submitBtn.innerHTML = `
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
        Send Message
      `;
    }
  });
</script>
