---
interface Props {
  activeTab?: string;
}

const { activeTab } = Astro.props;
const currentPath = Astro.url.pathname;

// Base URL handling for Astro deployments (e.g. GitHub Pages)
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");
const resolveUrl = (path: string) => {
  const cleanPath = path.startsWith("/") ? path : `/${path}`;
  if (cleanPath === "/") {
    return baseUrl === "" ? "/" : `${baseUrl}/`;
  }
  return `${baseUrl}${cleanPath}`;
};

const navItems = [
  { label: "Home", href: "/" },
  { label: "Simple Installation", href: "/simple-installation" },
  { label: "A La Carte", href: "/a-la-carte" },
  { label: "Fully Managed Remodel", href: "/fully-managed-remodel" },
];

const isLinkActive = (itemHref: string) => {
  if (activeTab) {
    return (
      activeTab.toLowerCase() === itemHref.replace("/", "").toLowerCase() ||
      (activeTab.toLowerCase() === "installation" && itemHref === "/")
    );
  }

  const resolvedHref = resolveUrl(itemHref);

  // Normalize paths for comparison (remove trailing slashes)
  const normPath = currentPath.replace(/\/$/, "");
  const normHref = resolvedHref.replace(/\/$/, "");

  return normPath === normHref;
};
---

<header class="site-header">
  <div class="nav-container container">
    <!-- Mobile hamburger trigger (left side on mobile — Popover API, no JS) -->
    <button class="mobile-toggle" popovertarget="mobile-nav" aria-label="Open navigation menu">
      <span aria-hidden="true">&#9776;</span>
      <span class="sr-only">Open menu</span>
    </button>

    <a
      href={resolveUrl("/")}
      class="brand-link"
      aria-label="IKEA Kitchen Installer Homepage"
    >
      IKEA Kitchen<span class="brand-accent">Installer</span>
    </a>

    <!-- Desktop nav links (visible above mobile breakpoint) -->
    <ul class="nav-menu desktop-nav">
      {
        navItems.map((item) => (
          <li class="nav-item">
            <a
              href={resolveUrl(item.href)}
              class={`nav-link ${isLinkActive(item.href) ? "active" : ""}`}
            >
              {item.label}
            </a>
          </li>
        ))
      }
      <li class="cta-container">
        <a href={resolveUrl("/contact")} class="btn-cta">Book Now</a>
      </li>
    </ul>
  </div>
</header>

<!-- Mobile nav popover drawer -->
<nav popover id="mobile-nav" class="mobile-nav-popover">
  <button
    class="mobile-nav-close"
    popovertarget="mobile-nav"
    popovertargetaction="hide"
    aria-label="Close navigation menu"
  >
    <span aria-hidden="true">&#10006;</span>
    <span class="sr-only">Close menu</span>
  </button>

  <div class="mobile-nav-brand">
    <a href={resolveUrl("/")} class="brand-link">
      IKEA Kitchen<span class="brand-accent">Installer</span>
    </a>
  </div>

  <ul class="mobile-nav-list">
    {
      navItems.map((item) => (
        <li>
          <a
            href={resolveUrl(item.href)}
            class={`mobile-nav-link ${isLinkActive(item.href) ? "active" : ""}`}
          >
            {item.label}
          </a>
        </li>
      ))
    }
    <li class="mobile-nav-cta">
      <a href={resolveUrl("/contact")} class="btn-cta">Book Now</a>
    </li>
  </ul>
</nav>
