---
interface Props {
  activeTab?: string;
}

const { activeTab } = Astro.props;
const currentPath = Astro.url.pathname;

// Base URL handling for Astro deployments (e.g. GitHub Pages)
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
const resolveUrl = (path: string) => {
  const cleanPath = path.startsWith('/') ? path : `/${path}`;
  if (cleanPath === '/') {
    return baseUrl === '' ? '/' : `${baseUrl}/`;
  }
  return `${baseUrl}${cleanPath}`;
};

const navItems = [
  { label: 'Planning', href: '/planning' },
  { label: 'Installation', href: '/' }, // Using home page as the main installation template view
  { label: 'General Contracting', href: '/general-contracting' },
  { label: 'Expertise', href: '/expertise' }
];

const isLinkActive = (itemHref: string) => {
  if (activeTab) {
    return activeTab.toLowerCase() === itemHref.replace('/', '').toLowerCase() || 
           (activeTab.toLowerCase() === 'installation' && itemHref === '/');
  }
  
  const resolvedHref = resolveUrl(itemHref);
  
  // Normalize paths for comparison (remove trailing slashes)
  const normPath = currentPath.replace(/\/$/, '');
  const normHref = resolvedHref.replace(/\/$/, '');
  
  return normPath === normHref;
};
---

<header class="site-header">
  <div class="nav-container container">
    <a href={resolveUrl('/')} class="brand-link" aria-label="Nordic Craft Installations Homepage">
      Nordic Craft<span class="brand-accent">Installations</span>
    </a>

    <button 
      class="mobile-toggle" 
      aria-label="Toggle Navigation Menu" 
      aria-expanded="false" 
      id="mobile-menu-toggle"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>

    <ul class="nav-menu" id="nav-menu">
      {navItems.map(item => (
        <li class="nav-item">
          <a 
            href={resolveUrl(item.href)} 
            class={`nav-link ${isLinkActive(item.href) ? 'active' : ''}`}
          >
            {item.label}
          </a>
        </li>
      ))}
      <li class="cta-container">
        <a href={resolveUrl('/quote')} class="btn-cta">Get Quote</a>
      </li>
    </ul>
  </div>
</header>

<script>
  // Mobile menu interactive logic
  const toggleBtn = document.getElementById('mobile-menu-toggle');
  const navMenu = document.getElementById('nav-menu');

  if (toggleBtn && navMenu) {
    toggleBtn.addEventListener('click', () => {
      const isActive = toggleBtn.classList.toggle('is-active');
      navMenu.classList.toggle('is-active');
      toggleBtn.setAttribute('aria-expanded', isActive ? 'true' : 'false');
    });

    // Close mobile menu when tabbing/clicking away or resizing
    const navLinks = document.querySelectorAll('.nav-link, .btn-cta, .brand-link');
    navLinks.forEach(link => {
      link.addEventListener('click', () => {
        toggleBtn.classList.remove('is-active');
        navMenu.classList.remove('is-active');
        toggleBtn.setAttribute('aria-expanded', 'false');
      });
    });
  }
</script>
