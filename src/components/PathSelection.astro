---
---

<section class="landing-section">
  <div class="container">
    <h2 class="section-title">Choose Your Path to a New Kitchen</h2>
    <p class="section-intro">
      Whether you need a straightforward installation or a comprehensive remodel experience, we have the expertise to bring your vision to life.
    </p>

    <div class="path-grid">
      <!-- Card 1: Simple/Basic Install -->
      <div class="path-card">
        <div class="path-card-top">
          <div class="path-card-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"></path></svg>
          </div>
          <h3 class="path-card-title">Simple/Basic Install</h3>
          <p class="path-card-desc">
            Focus on professional assembly and precision installation based solely on your IKEA plan. Ideal for those who have their trades already lined up.
          </p>
        </div>
        <button class="btn-select" aria-label="Select Simple Install Path">Select Simple Install</button>
      </div>

      <!-- Card 2: A La Carte -->
      <div class="path-card">
        <div class="path-card-top">
          <div class="path-card-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="21" x2="4" y2="14"></line><line x1="4" y1="10" x2="4" y2="3"></line><line x1="12" y1="21" x2="12" y2="12"></line><line x1="12" y1="8" x2="12" y2="3"></line><line x1="20" y1="21" x2="20" y2="16"></line><line x1="20" y1="12" x2="20" y2="3"></line><line x1="1" y1="14" x2="7" y2="14"></line><line x1="9" y1="8" x2="15" y2="8"></line><line x1="17" y1="16" x2="23" y2="16"></line></svg>
          </div>
          <h3 class="path-card-title">A La Carte</h3>
          <p class="path-card-desc">
            The middle path. Simple installation plus your choice of finishes like flooring, backsplashes, and custom details. Pick and choose exactly what you need.
          </p>
        </div>
        <button class="btn-select" aria-label="Select A La Carte Path">Select A La Carte</button>
      </div>

      <!-- Card 3: Fully Managed Remodel (Dark card) -->
      <div class="path-card dark-card">
        <div class="path-card-top">
          <div class="path-card-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
          </div>
          <h3 class="path-card-title">Fully Managed Remodel</h3>
          <p class="path-card-desc">
            Complete project management, including trade coordination, flooring, and custom finishes for a stress-free transformation of your dreams.
          </p>
        </div>
        <button class="btn-select" aria-label="Select Fully Managed Remodel Path">Select Full Remodel</button>
      </div>
    </div>
  </div>
</section>
