---
import faucetInstall from '../assets/faucet_install.png';

// Base URL helper
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
const resolveUrl = (path: string) => {
  const cleanPath = path.startsWith('/') ? path : `/${path}`;
  if (cleanPath === '/') {
    return baseUrl === '' ? '/' : `${baseUrl}/`;
  }
  return `${baseUrl}${cleanPath}`;
};
---

<section class="landing-section">
  <div class="container">
    <h2 class="section-title">The IKEA Quote Baseline</h2>
    <p class="section-intro">
      We believe in a fair start. Our pricing model is built on honesty, starting exactly where the manufacturer begins.
    </p>

    <div class="baseline-grid">
      <!-- Card 1: Start at the Baseline -->
      <div class="baseline-card">
        <div class="card-top">
          <div class="baseline-card-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
          </div>
          <h3 class="baseline-card-title">Start at the Baseline</h3>
          <p class="baseline-card-desc">
            The cost for our services starts at the cost you got quoted from IKEA. We use their standard pricing matrices as our foundation and benchmark for transparency.
          </p>
        </div>
      </div>

      <!-- Card 2: Simple to Ask (Dark Card) -->
      <div class="baseline-card dark-card">
        <div class="card-top">
          <div class="baseline-card-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>
          </div>
          <h3 class="baseline-card-title">Simple to Ask</h3>
          <p class="baseline-card-desc">
            When buying your kitchen, simply request an installation quote. There is <strong>no charge or obligation</strong> for "clicking" that option. It will give you a definitive cost for a simple installation.
          </p>
        </div>
        <a href={resolveUrl('/how-it-works')} class="btn-learn">
          Learn More
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
        </a>
        <div class="dark-card-bg-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>
        </div>
      </div>

      <!-- Card 3: The Advantage (Horizontal Layout) -->
      <div class="baseline-card advantage-card">
        <div class="advantage-content">
          <h3 class="baseline-card-title" style="margin-bottom: 12px;">The Advantage</h3>
          <p class="baseline-card-desc" style="font-size: 1rem;">
            For relatively simple projects, we will honor the IKEA price, while offering <strong>plumbing and appliance connections included</strong>—services you would need to find, evaluate, and then determine who to contract for the job.
          </p>
        </div>
        <div class="advantage-img-wrapper">
          <img 
            class="advantage-img" 
            src={faucetInstall.src} 
            alt="Plumber finishing kitchen faucet installation work" 
            loading="lazy"
          />
        </div>
      </div>

      <!-- Card 4: Zero Risk Commitment -->
      <div class="baseline-card">
        <div class="card-top">
          <div class="baseline-card-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
          </div>
          <h3 class="baseline-card-title">Zero Risk Commitment</h3>
          <p class="baseline-card-desc">
            You really can't lose. You get simple plumbing and appliance connections included without having to hire a plumber and an electrician yourself, just to use the kitchen you bought and paid to have installed.
          </p>
        </div>
        <a href={resolveUrl('/warranty')} class="warranty-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
          5-year Workmanship warranty
        </a>
      </div>
    </div>
  </div>
</section>
