---
const currentYear = new Date().getFullYear();

// Base URL helper
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
const resolveUrl = (path: string) => {
  const cleanPath = path.startsWith('/') ? path : `/${path}`;
  if (cleanPath === '/') {
    return baseUrl === '' ? '/' : `${baseUrl}/`;
  }
  return `${baseUrl}${cleanPath}`;
};
---

<footer class="site-footer">
  <div class="footer-container container">
    <div class="footer-brand-section">
      <a href={resolveUrl('/')} class="footer-logo" aria-label="IKEA Kitchen Installer Homepage">
        <span class="logo-dot"></span>
        IKEA KITCHEN INSTALLER
      </a>
      <p class="footer-brand-desc">
        Providing precision installation services for the modern homeowner. We are independent service providers, not affiliated with IKEA systems.
      </p>
    </div>

    <div class="footer-links-grid">
      <div class="footer-column">
        <h3 class="footer-heading">Explore</h3>
        <ul class="footer-list">
          <li><a href={resolveUrl('/services')} class="footer-link">Services</a></li>
          <li><a href={resolveUrl('/contact')} class="footer-link">Contact</a></li>
          <li><a href="mailto:ikakitcheninstallers@gmail.com" class="footer-link mail-link">ikakitcheninstallers@gmail.com</a></li>
          <li><a href={resolveUrl('/warranty')} class="footer-link">Warranty</a></li>
        </ul>
      </div>

      <div class="footer-column">
        <h3 class="footer-heading">Legal</h3>
        <ul class="footer-list">
          <li><a href={resolveUrl('/privacy')} class="footer-link">Privacy Policy</a></li>
          <li><a href={resolveUrl('/terms')} class="footer-link">Terms of Service</a></li>
        </ul>
      </div>
    </div>
  </div>

  <div class="footer-bottom container">
    <p class="copyright">
      &copy; {currentYear} ikeakitcheninstaller.ca. Independent service providers, not affiliated with Inter IKEA Systems B.V.
    </p>
  </div>
</footer>

<style>
  /* Footer styles */
  .site-footer {
    background-color: #f4f8fa;
    border-top: 1px solid #e2e8f0;
    padding: 80px 0 40px 0;
    font-family: var(--font-primary);
  }

  .footer-container {
    display: flex;
    justify-content: space-between;
    gap: 48px;
    margin-bottom: 60px;
    flex-wrap: wrap;
  }

  .footer-brand-section {
    flex: 1.5;
    min-width: 280px;
    max-width: 400px;
  }

  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-brand-dark);
    letter-spacing: -0.01em;
    margin-bottom: 20px;
  }

  .logo-dot {
    width: 12px;
    height: 12px;
    background-color: #2e7d32; /* Green mark from design */
    border-radius: 50%;
    display: inline-block;
  }

  .footer-brand-desc {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--color-text-muted);
  }

  .footer-links-grid {
    display: flex;
    gap: 80px;
    flex: 2;
    justify-content: flex-end;
    flex-wrap: wrap;
  }

  .footer-column {
    min-width: 140px;
  }

  .footer-heading {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-brand-dark);
    margin-bottom: 20px;
    letter-spacing: 0.02em;
  }

  .footer-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer-link {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    transition: color var(--transition-smooth);
  }

  .footer-link:hover {
    color: var(--color-text-primary);
  }

  .mail-link {
    word-break: break-all;
  }

  .footer-bottom {
    border-top: 1px solid rgba(226, 232, 240, 0.8);
    padding-top: 30px;
    display: flex;
    justify-content: center;
  }

  .copyright {
    font-size: 0.8rem;
    color: #888888;
    text-align: center;
    line-height: 1.5;
    max-width: 800px;
  }

  @media (max-width: 768px) {
    .footer-container {
      flex-direction: column;
      gap: 40px;
    }
    .footer-links-grid {
      justify-content: flex-start;
      gap: 40px;
    }
  }
</style>
